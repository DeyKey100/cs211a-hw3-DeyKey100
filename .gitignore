опубликовать/

# Опубликовать веб-выходные данные 
*.[Pp]ublish.xml 
*.azurePubxml
# Примечание: Прокомментируйте следующую строку, если вы хотите проверить настройки веб-развертывания,
# но строки подключения к базе данных (с возможными паролями) будут незашифрованными 
*.pubxml
*.publishproj

# Настройки публикации веб-приложения Microsoft Azure. Прокомментируйте следующую строку, если хотите
# проверка настроек публикации в веб-приложении Azure, но конфиденциальная информация, содержащаяся
# в этих скриптах, будет незашифрованной
PublishScripts/

# Пакеты NuGet
*.nupkg
# Пакеты NuGet Symbol
*.snupkg
# Папку packages можно игнорировать из-за восстановления пакетов
**/[Pp]ackages/*
# кроме build/, которая используется в качестве цели MSBuild.
!**/[Pp]ackages/build/
# При необходимости раскомментируйте, но, как правило, файл будет создан заново при необходимости
#!**/[Pp]ackages/repositories.config
# Файлы project.json в NuGet v3 создают больше игнорируемых файлов
*.nuget.props
*.nuget.targets

# Выходные данные сборки Microsoft Azure
csx/
*.build.csdef

# Эмулятор Microsoft Azure
ecf/
rcf/

# Каталоги и файлы пакетов приложений для Магазина Windows
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle 
*.appxupload

# Файлы кэша Visual Studio
# файлы, оканчивающиеся на .cache, можно игнорировать 
*.[Cc]ache
# но следите за каталогами, заканчивающимися на .cache 
!?*.[Cc]ache/

